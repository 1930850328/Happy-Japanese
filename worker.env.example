# Vercel API 与 Worker 必须使用同一个 Redis 和队列前缀。
SONG_ANALYSIS_REDIS_URL=rediss://default:replace-me@redis.example.com:6380/0
SONG_ANALYSIS_QUEUE_PREFIX=happy-japanese

# 可选：不设置时使用 Codex 登录账号的默认模型。
# CODEX_MODEL=
SONG_ANALYSIS_AGENT_TIMEOUT_MS=300000
SONG_ANALYSIS_JOB_ATTEMPTS=2
SONG_ANALYSIS_RETRY_DELAY_MS=5000
